# Core Environment
ENVIRONMENT=development
DEBUG=true

# GCP Project
GCP_PROJECT_ID=buildtrace-dev
GOOGLE_CLOUD_PROJECT=buildtrace-dev
REGION=us-west2
ZONE=us-west2-a

# Database Configuration (for Cloud SQL Proxy)
USE_DATABASE=true
DB_HOST=localhost
DB_PORT=5432
DB_USER=buildtrace_user
DB_PASS=user98765tracebuild
DB_NAME=buildtrace_db
INSTANCE_CONNECTION_NAME=buildtrace-dev:us-west2:buildtrace-dev-db

# Storage Configuration (using local storage for dev)
USE_GCS=true
LOCAL_UPLOAD_PATH=uploads
LOCAL_RESULTS_PATH=results
LOCAL_TEMP_PATH=temp
# GCS buckets (for reference, not used when USE_GCS=true)
GCS_BUCKET_NAME=buildtrace-dev-input-buildtrace-dev
GCS_UPLOAD_BUCKET=buildtrace-dev-input-buildtrace-dev
GCS_PROCESSED_BUCKET=buildtrace-dev-processed-buildtrace-dev

# Pub/Sub Configuration (disabled for local dev)
USE_PUBSUB=false
PUBSUB_OCR_TOPIC=buildtrace-dev-ocr-queue
PUBSUB_DIFF_TOPIC=buildtrace-dev-diff-queue
PUBSUB_SUMMARY_TOPIC=buildtrace-dev-summary-queue
PUBSUB_OCR_SUBSCRIPTION=buildtrace-dev-ocr-worker-sub
PUBSUB_DIFF_SUBSCRIPTION=buildtrace-dev-diff-worker-sub
PUBSUB_SUMMARY_SUBSCRIPTION=buildtrace-dev-summary-worker-sub

# OpenAI Configuration
OPENAI_API_KEY=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
OPENAI_MODEL=gpt-4o
USE_AI_ANALYSIS=true
FRONTEND_URL=http://localhost:3000

# Application Settings
APP_NAME=BuildTrace
SECRET_KEY=dev-secret-key-change-in-production
HOST=0.0.0.0
PORT=5001

# Processing Settings
MAX_CONTENT_LENGTH=73400320
PROCESSING_TIMEOUT=3600
DEFAULT_DPI=300
MAX_SYNC_PAGES=10
MEMORY_LIMIT_GB=10.0
MAX_UPLOAD_SIZE_MB=70

# Feature Flags
USE_ASYNC_PROCESSING=true
USE_FIREBASE_AUTH=false
SESSION_LIFETIME_HOURS=24
CLEANUP_OLD_SESSIONS=true

